{"id":112,"name":"Al-Ikhlas","nameArabic":"الإخلاص","transliteration":"Al-Ikhlas","type":"meccan","ayahCount":4,"verses":[{"n":1,"text":"قُلۡ هُوَ ٱللَّهُ أَحَدٌ","translit":"Qul huwa Allahu ahadun","translation":"Say, \"He is Allah, [who is] One"},{"n":2,"text":"ٱللَّهُ ٱلصَّمَدُ","translit":"Allahu alssamadu","translation":"Allah, the Eternal Refuge"},{"n":3,"text":"لَمۡ يَلِدۡ وَلَمۡ يُولَدۡ","translit":"Lam yalid walam yooladu","translation":"He neither begets nor is born"},{"n":4,"text":"وَلَمۡ يَكُن لَّهُۥ كُفُوًا أَحَدُۢ","translit":"Walam yakun lahu kufuwan ahadun","translation":"Nor is there to Him any equivalent"}]}