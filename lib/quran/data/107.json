{"id":107,"name":"Al-Ma'un","nameArabic":"الماعون","transliteration":"Al-Ma'un","type":"meccan","ayahCount":7,"verses":[{"n":1,"text":"أَرَءَيۡتَ ٱلَّذِي يُكَذِّبُ بِٱلدِّينِ","translit":"Araayta allathee yukaththibu bialddeeni","translation":"Have you seen the one who denies the Recompense"},{"n":2,"text":"فَذَٰلِكَ ٱلَّذِي يَدُعُّ ٱلۡيَتِيمَ","translit":"Fathalika allathee yaduAAAAu alyateema","translation":"For that is the one who drives away the orphan"},{"n":3,"text":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ","translit":"Wala yahuddu AAala taAAami almiskeeni","translation":"And does not encourage the feeding of the poor"},{"n":4,"text":"فَوَيۡلٞ لِّلۡمُصَلِّينَ","translit":"Fawaylun lilmusalleena","translation":"So woe to those who pray"},{"n":5,"text":"ٱلَّذِينَ هُمۡ عَن صَلَاتِهِمۡ سَاهُونَ","translit":"Allatheena hum AAan salatihim sahoona","translation":"[But] who are heedless of their prayer"},{"n":6,"text":"ٱلَّذِينَ هُمۡ يُرَآءُونَ","translit":"Allatheena hum yuraoona","translation":"Those who make show [of their deeds]"},{"n":7,"text":"وَيَمۡنَعُونَ ٱلۡمَاعُونَ","translit":"WayamnaAAoona almaAAoona","translation":"And withhold [simple] assistance"}]}