{"id":96,"name":"Al-'Alaq","nameArabic":"العلق","transliteration":"Al-'Alaq","type":"meccan","ayahCount":19,"verses":[{"n":1,"text":"ٱقۡرَأۡ بِٱسۡمِ رَبِّكَ ٱلَّذِي خَلَقَ","translit":"Iqra biismi rabbika allathee khalaqa","translation":"Recite in the name of your Lord who created"},{"n":2,"text":"خَلَقَ ٱلۡإِنسَٰنَ مِنۡ عَلَقٍ","translit":"Khalaqa alinsana min AAalaqin","translation":"Created man from a clinging substance"},{"n":3,"text":"ٱقۡرَأۡ وَرَبُّكَ ٱلۡأَكۡرَمُ","translit":"Iqra warabbuka alakramu","translation":"Recite, and your Lord is the most Generous"},{"n":4,"text":"ٱلَّذِي عَلَّمَ بِٱلۡقَلَمِ","translit":"Allathee AAallama bialqalami","translation":"Who taught by the pen"},{"n":5,"text":"عَلَّمَ ٱلۡإِنسَٰنَ مَا لَمۡ يَعۡلَمۡ","translit":"AAallama alinsana ma lam yaAAlam","translation":"Taught man that which he knew not"},{"n":6,"text":"كَلَّآ إِنَّ ٱلۡإِنسَٰنَ لَيَطۡغَىٰٓ","translit":"Kalla inna alinsana layatgha","translation":"No! [But] indeed, man transgresses"},{"n":7,"text":"أَن رَّءَاهُ ٱسۡتَغۡنَىٰٓ","translit":"An raahu istaghna","translation":"Because he sees himself self-sufficient"},{"n":8,"text":"إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجۡعَىٰٓ","translit":"Inna ila rabbika alrrujAAa","translation":"Indeed, to your Lord is the return"},{"n":9,"text":"أَرَءَيۡتَ ٱلَّذِي يَنۡهَىٰ","translit":"Araayta allathee yanha","translation":"Have you seen the one who forbids"},{"n":10,"text":"عَبۡدًا إِذَا صَلَّىٰٓ","translit":"AAabdan itha salla","translation":"A servant when he prays"},{"n":11,"text":"أَرَءَيۡتَ إِن كَانَ عَلَى ٱلۡهُدَىٰٓ","translit":"Araayta in kana AAala alhuda","translation":"Have you seen if he is upon guidance"},{"n":12,"text":"أَوۡ أَمَرَ بِٱلتَّقۡوَىٰٓ","translit":"Aw amara bialttaqwa","translation":"Or enjoins righteousness"},{"n":13,"text":"أَرَءَيۡتَ إِن كَذَّبَ وَتَوَلَّىٰٓ","translit":"Araayta in kaththaba watawalla","translation":"Have you seen if he denies and turns away"},{"n":14,"text":"أَلَمۡ يَعۡلَم بِأَنَّ ٱللَّهَ يَرَىٰ","translit":"Alam yaAAlam bianna Allaha yara","translation":"Does he not know that Allah sees"},{"n":15,"text":"كَلَّا لَئِن لَّمۡ يَنتَهِ لَنَسۡفَعَۢا بِٱلنَّاصِيَةِ","translit":"Kalla lain lam yantahi lanasfaAAan bialnnasiyati","translation":"No! If he does not desist, We will surely drag him by the forelock"},{"n":16,"text":"نَاصِيَةٖ كَٰذِبَةٍ خَاطِئَةٖ","translit":"Nasiyatin kathibatin khatiatin","translation":"A lying, sinning forelock"},{"n":17,"text":"فَلۡيَدۡعُ نَادِيَهُۥ","translit":"FalyadAAu nadiyahu","translation":"Then let him call his associates"},{"n":18,"text":"سَنَدۡعُ ٱلزَّبَانِيَةَ","translit":"SanadAAu alzzabaniyata","translation":"We will call the angels of Hell"},{"n":19,"text":"كَلَّا لَا تُطِعۡهُ وَٱسۡجُدۡۤ وَٱقۡتَرِب۩","translit":"Kalla la tutiAAhu waosjud waiqtarib","translation":"No! Do not obey him. But prostrate and draw near [to Allah]"}]}