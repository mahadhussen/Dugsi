{"id":114,"name":"An-Nas","nameArabic":"الناس","transliteration":"An-Nas","type":"meccan","ayahCount":6,"verses":[{"n":1,"text":"قُلۡ أَعُوذُ بِرَبِّ ٱلنَّاسِ","translit":"Qul aAAoothu birabbi alnnasi","translation":"Say, \"I seek refuge in the Lord of mankind"},{"n":2,"text":"مَلِكِ ٱلنَّاسِ","translit":"Maliki alnnasi","translation":"The Sovereign of mankind"},{"n":3,"text":"إِلَٰهِ ٱلنَّاسِ","translit":"Ilahi alnnasi","translation":"The God of mankind"},{"n":4,"text":"مِن شَرِّ ٱلۡوَسۡوَاسِ ٱلۡخَنَّاسِ","translit":"Min sharri alwaswasi alkhannasi","translation":"From the evil of the retreating whisperer"},{"n":5,"text":"ٱلَّذِي يُوَسۡوِسُ فِي صُدُورِ ٱلنَّاسِ","translit":"Allathee yuwaswisu fee sudoori alnnasi","translation":"Who whispers [evil] into the breasts of mankind"},{"n":6,"text":"مِنَ ٱلۡجِنَّةِ وَٱلنَّاسِ","translit":"Mina aljinnati wa alnnasm","translation":"From among the jinn and mankind"}]}