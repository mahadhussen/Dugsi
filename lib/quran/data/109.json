{"id":109,"name":"Al-Kafirun","nameArabic":"الكافرون","transliteration":"Al-Kafirun","type":"meccan","ayahCount":6,"verses":[{"n":1,"text":"قُلۡ يَـٰٓأَيُّهَا ٱلۡكَٰفِرُونَ","translit":"Qul ya ayyuha alkafiroona","translation":"Say, \"O disbelievers"},{"n":2,"text":"لَآ أَعۡبُدُ مَا تَعۡبُدُونَ","translit":"La aAAbudu ma taAAbudoona","translation":"I do not worship what you worship"},{"n":3,"text":"وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ","translit":"Wala antum AAabidoona ma aAAbudu","translation":"Nor are you worshippers of what I worship"},{"n":4,"text":"وَلَآ أَنَا۠ عَابِدٞ مَّا عَبَدتُّمۡ","translit":"Wala ana AAabidun ma AAabadtum","translation":"Nor will I be a worshipper of what you worship"},{"n":5,"text":"وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ","translit":"Wala antum AAabidoona ma aAAbudu","translation":"Nor will you be worshippers of what I worship"},{"n":6,"text":"لَكُمۡ دِينُكُمۡ وَلِيَ دِينِ","translit":"Lakum deenukum waliya deeni","translation":"For you is your religion, and for me is my religion"}]}