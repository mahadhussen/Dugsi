{"id":113,"name":"Al-Falaq","nameArabic":"الفلق","transliteration":"Al-Falaq","type":"meccan","ayahCount":5,"verses":[{"n":1,"text":"قُلۡ أَعُوذُ بِرَبِّ ٱلۡفَلَقِ","translit":"Qul aAAoothu birabbi alfalaqi","translation":"Say, \"I seek refuge in the Lord of daybreak"},{"n":2,"text":"مِن شَرِّ مَا خَلَقَ","translit":"Min sharri ma khalaqa","translation":"From the evil of that which He created"},{"n":3,"text":"وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ","translit":"Wamin sharri ghasiqin itha waqaba","translation":"And from the evil of darkness when it settles"},{"n":4,"text":"وَمِن شَرِّ ٱلنَّفَّـٰثَٰتِ فِي ٱلۡعُقَدِ","translit":"Wamin sharri alnnaffathati fee alAAuqadi","translation":"And from the evil of the blowers in knots"},{"n":5,"text":"وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ","translit":"Wamin sharri hasidin itha hasada","translation":"And from the evil of an envier when he envies"}]}