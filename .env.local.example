# Dugsi runs fully free and on-device by default — NO key or env vars are needed.
#
# This file only matters if you later enable the optional, opt-in on-device /
# server Whisper engine for higher accuracy (see lib/transcribe). It is unused by
# the default browser-based recogniser.

# OPENAI_API_KEY=sk-...
# DUGSI_TRANSCRIBER=whisper
